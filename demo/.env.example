DEMO_IMAGE_TAG=latest
# Match the host user that owns docker/volumes/.
PUID=1000
PGID=1000

######### LGOS API #########
LGOS_OPENAI_API_PREFIX=/v1
LGOS_OPENAI_API_DOCS_ENABLED=False
LGOS_ENABLE_LANGFUSE=False

LANGFUSE_BASE_URL=TO_BE_FILLED
LANGFUSE_PUBLIC_KEY=TO_BE_FILLED
LANGFUSE_SECRET_KEY=TO_BE_FILLED

######### DEMO API #########
DEMO_API_OPENAI_API_KEY=TO_BE_FILLED
DEMO_API_OPENAI_BASE_URL=https://api.openai.com/v1
DEMO_API_OPENAI_MODEL=gpt-5.4-mini
DEMO_API_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
DEMO_API_POSTGRES_URI=postgresql://lgos:lgos@localhost:5432/lgos

######### CHAINLIT #########
CHAINLIT_APP_ROOT=src/lgos_chainlit
CHAINLIT_AUTH_SECRET=TO_BE_FILLED
DATABASE_URL=postgresql://lgos:lgos@localhost:5432/lgos

### OPTIONAL CHAINLIT OAUTH ###
# OAUTH_GENERIC_CLIENT_ID=TO_BE_FILLED
# OAUTH_GENERIC_CLIENT_SECRET=TO_BE_FILLED
# OAUTH_GENERIC_AUTH_URL=https://pocketid.example.com/authorize
# OAUTH_GENERIC_TOKEN_URL=https://pocketid.example.com/api/oidc/token
# OAUTH_GENERIC_USER_INFO_URL=https://pocketid.example.com/api/oidc/userinfo
# OAUTH_GENERIC_SCOPES="openid profile email groups"
# OAUTH_GENERIC_NAME=PocketID
# OAUTH_GENERIC_USER_IDENTIFIER=sub

DEMO_CHAINLIT_INFERENCE__BASE_URL=http://localhost:8000/v1
DEMO_CHAINLIT_INFERENCE__API_KEY=DUMMY
# DEMO_CHAINLIT_INFERENCE_MODEL_PREFIX=openai/
# DEMO_CHAINLIT_DISCOVERY__BASE_URL=http://localhost:8000/v1
# DEMO_CHAINLIT_DISCOVERY__API_KEY=DUMMY
DEMO_CHAINLIT_HITL_MODEL=interruptible-approval
DEMO_CHAINLIT_LOGIN_TYPE=mock
DEMO_CHAINLIT_UI_FILE=simple

######### OPEN WEBUI #########
DEMO_OPENWEBUI_URL=http://localhost:8080
DEMO_OPENWEBUI_ADMIN_EMAIL=lgos@example.com
DEMO_OPENWEBUI_ADMIN_PASSWORD=lgos
DEMO_OPENWEBUI_SECRET_KEY=lgos-demo-only-secret
